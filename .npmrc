# Memaksa semua developer dan CI/CD menggunakan versi Node & Package Manager yang sesuai
engine-strict=true

# Otomatis menginstal peer dependencies yang dibutuhkan oleh library pihak ketiga
auto-install-peers=true

# Mencegah kegagalan install jika ada ketidakcocokan versi peer dependency yang minor
strict-peer-dependencies=false

# REKOMENDASI UTAMA: Tetap gunakan mode ketat (false) untuk mencegah phantom dependencies.
# Ubah ke true HANYA JIKA ada library pihak ketiga yang rusak parah karena struktur symlink.
shamefully-hoist=false

# Mengatur agar pnpm membuat lockfile yang kompatibel dalam lingkungan monorepo/workspace
shared-workspace-lockfile=true
